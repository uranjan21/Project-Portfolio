{
  "name": "project-portfolio",
  "private": true,
  "version": "1.0.0",
  "description": "Cinematic HUD-style portfolio for Utsav Ranjan — React + TypeScript client, Express + TypeScript API",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run typecheck && vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "preview": "npm run build && npm run start",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "framer-motion": "^11.15.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.15.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.13.8",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
