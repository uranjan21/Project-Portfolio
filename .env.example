# --- Server ---
PORT=5177

# Public URL of the deployed site (no trailing slash). Used for canonical
# links, Open Graph URLs, robots.txt and sitemap.xml. Falls back to the
# request host when unset.
SITE_URL=

# Password required to enter admin mode on the site (footer > ADMIN).
# CHANGE THIS before deploying.
ADMIN_PASSWORD=change-me

# Secret used to sign admin session tokens (JWT). Any long random string.
# If unset, a random secret is generated at boot (sessions reset on restart).
SESSION_SECRET=

# --- Chat assistant (optional) ---
# Without a key the assistant still answers from the FAQ list; with a key it
# also answers free-form questions grounded in the portfolio content.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Owner notifications for unanswered questions (optional) ---
# Unanswered visitor questions always land in the admin inbox on the site.
# Configure SMTP to additionally receive them by email.
NOTIFY_EMAIL=utsavranjan.sk@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
